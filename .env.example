# App
NODE_ENV=development
PORT=3000
PUBLIC_URL=https://recordings.meetingmindsgroup.com

# Database
DATABASE_URL=postgres://mmg:mmg@localhost:5433/mmg_recordings

# AWS
AWS_REGION=me-central-1
S3_BUCKET=mmg-recordings-bahrain
# Omit AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY on EC2 and use an instance profile.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Zoom (Server-to-Server OAuth app)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# DIFFERENT from ZOOM_CLIENT_SECRET. Set in the Zoom Marketplace app's Feature tab.
ZOOM_WEBHOOK_SECRET_TOKEN=

# AssemblyAI
ASSEMBLYAI_API_KEY=
# Shared secret we define; AssemblyAI echoes it back in the webhook auth header.
ASSEMBLYAI_WEBHOOK_SECRET=

# Trigger.dev
TRIGGER_SECRET_KEY=
TRIGGER_API_URL=https://api.trigger.dev

# Dropbox
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=

# FFmpeg worker (internal)
FFMPEG_WORKER_URL=http://127.0.0.1:8080
FFMPEG_WORKER_SHARED_SECRET=

# Slack
SLACK_WEBHOOK_URL=
